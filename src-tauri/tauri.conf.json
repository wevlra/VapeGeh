{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VapeGeh",
  "version": "1.0.0",
  "identifier": "com.wevlra.vapegeh",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:8000?__tauri=1",
    "beforeBuildCommand": "",
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "VapeGeh",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "VapeGeh",
        "url": "/splashscreen.html",
        "width": 480,
        "height": 400,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
